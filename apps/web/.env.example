# Required. Browser-safe Supabase project settings. Also used at BUILD time by
# the prerender step to fetch the public CMS snapshot + slug redirects.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Canonical public origin (no trailing slash). Used to generate canonical URLs,
# Open Graph URLs, sitemap.xml, and robots.txt during the prerender build.
VITE_SITE_URL=https://www.designingminds.co.za

# Build-time only. Origin of the deployed functions app. The prerender step
# writes a Vercel Build Output route that proxies /api/* to this origin.
# REQUIRED on Vercel (the build fails without it); a placeholder is used locally.
WEB_FUNCTIONS_ORIGIN=https://your-functions-project.vercel.app

# Optional. Leave blank when vercel.json / the generated Build Output proxies
# /api/* to the functions app (same-origin). Set only to call functions directly.
VITE_API_BASE_URL=

# Optional local-dev override for the Vite /api proxy target (default :8787).
VITE_API_PROXY_TARGET=

# Optional. Set to "true" to let `npm run build` succeed with an empty snapshot
# when Supabase is unreachable (local builds only — never in production).
ALLOW_EMPTY_PRERENDER=
