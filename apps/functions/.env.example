PORT=8787
SITE_URL=
ALLOWED_ORIGINS=

SUPABASE_URL=
SUPABASE_SECRET_KEY=
STORAGE_BUCKET=

# Vercel Deploy Hook for the WEB project. Treated as a secret — possession is
# enough to trigger a deployment, so it lives only here (never in the browser).
# Vercel: Web project → Settings → Git → Deploy Hooks → create one for the
# production branch, then paste its URL here. Powers POST /api/admin/rebuild-web.
VERCEL_WEB_DEPLOY_HOOK_URL=

# true skips the real PayFast handoff and routes to /checkout/fake-payfast.
FAKE_PAYFAST_ENABLED=false

PAYFAST_MODE=sandbox
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_ALLOWED_IPS=
