# ─── Server / HTTP ──────────────────────────────────────────────────────────

# Local dev server port (apps/functions/src/server.ts). Ignored on Vercel,
# which routes each handler through the API adapter. Defaults to 8787.
PORT=8787

# Public origin of the storefront (no trailing slash). Used to build PayFast
# return/cancel/notify URLs during checkout. REQUIRED in production — checkout
# throws without it. Falls back to Vercel's auto-injected
# VERCEL_PROJECT_PRODUCTION_URL when unset, e.g. https://www.designingminds.co.za
SITE_URL=

# Comma-separated list of browser origins allowed to call the API (CORS).
# localhost / 127.0.0.1 are always allowed in the local dev server. Set this to
# the deployed web + admin origins in production, e.g.
# https://www.designingminds.co.za,https://admin.designingminds.co.za
ALLOWED_ORIGINS=

# ─── Supabase ────────────────────────────────────────────────────────────────

# Supabase project settings for server-side access. The SECRET (service-role)
# key bypasses row-level security — keep it server-only, never expose it to the
# browser. Both are required.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Supabase Storage bucket that holds purchasable/downloadable package assets.
# Required — signed upload/download URLs throw without it.
STORAGE_BUCKET=

# ─── Transactional email (Resend) ────────────────────────────────────────────

# Resend transactional email (form-submission notifications; purchase emails
# later). Leave blank to disable sending — submissions are still stored, the
# notification is just skipped with a warning. To go live:
#   RESEND_API_KEY        API key from resend.com
#   RESEND_FROM           verified sender, e.g. "Designing Minds <noreply@designingminds.co.za>"
#   FORM_NOTIFICATIONS_TO inbox that receives contact + newsletter submissions
RESEND_API_KEY=
RESEND_FROM=
FORM_NOTIFICATIONS_TO=

# ─── Deployment ──────────────────────────────────────────────────────────────

# Vercel Deploy Hook for the WEB project. Treated as a secret — possession is
# enough to trigger a deployment, so it lives only here (never in the browser).
# Vercel: Web project → Settings → Git → Deploy Hooks → create one for the
# production branch, then paste its URL here. Powers POST /api/admin/rebuild-web.
VERCEL_WEB_DEPLOY_HOOK_URL=

# ─── PayFast payments ────────────────────────────────────────────────────────

# PayFast environment: "sandbox" (default) or "live". Selects the process +
# validate endpoints and which PayFast hosts the ITN source IP is checked
# against. Sandbox runs the SAME signature/IP/validate checks as live so the
# sandbox behaves like production — it just points at sandbox.payfast.co.za.
PAYFAST_MODE=sandbox

# PayFast account credentials from the merchant dashboard.
#   - LIVE:    merchant ID + key are REQUIRED (checkout throws without them).
#   - SANDBOX: leave both blank to use PayFast's public sandbox test account
#              (merchant_id 10000100 / merchant_key 46f0cd694581a). Set them
#              only to use your own sandbox account from sandbox.payfast.co.za.
# The passphrase salts the request signature — set the EXACT value configured on
# your PayFast account. Leave it blank when using the default sandbox account
# (that account has no passphrase; a mismatch breaks signature validation).
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# Optional override for ITN source-IP validation. Normally leave blank: the
# webhook resolves PayFast's official ITN hosts via DNS at request time
# (sandbox.payfast.co.za in sandbox; www/w1w/w2w.payfast.co.za in live) — PayFast
# rotates these IPs, so DNS is more robust than a static list. Set this
# comma-separated allowlist only to pin specific IPs or for offline testing; a
# matching entry here short-circuits the DNS lookup.
PAYFAST_ALLOWED_IPS=
