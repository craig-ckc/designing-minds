PORT=8787
SITE_URL=
ALLOWED_ORIGINS=

SUPABASE_URL=
SUPABASE_SECRET_KEY=
STORAGE_BUCKET=

# Resend transactional email (form-submission notifications; purchase emails
# later). Leave blank to disable sending — submissions are still stored, the
# notification is just skipped with a warning. To go live:
#   RESEND_API_KEY        API key from resend.com
#   RESEND_FROM           verified sender, e.g. "Designing Minds <noreply@designingminds.co.za>"
#   FORM_NOTIFICATIONS_TO inbox that receives contact + newsletter submissions
RESEND_API_KEY=
RESEND_FROM=
FORM_NOTIFICATIONS_TO=

# Vercel Deploy Hook for the WEB project. Treated as a secret — possession is
# enough to trigger a deployment, so it lives only here (never in the browser).
# Vercel: Web project → Settings → Git → Deploy Hooks → create one for the
# production branch, then paste its URL here. Powers POST /api/admin/rebuild-web.
VERCEL_WEB_DEPLOY_HOOK_URL=

# true skips the real PayFast handoff and routes to /checkout/fake-payfast.
FAKE_PAYFAST_ENABLED=false

PAYFAST_MODE=sandbox
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_ALLOWED_IPS=
