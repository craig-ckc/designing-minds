# Required. Browser-safe Supabase project settings for the admin app.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Required. Used by the "Preview" link in the admin top bar.
VITE_WEB_URL=https://www.your-domain.example

# Optional. Leave blank when admin/vercel.json rewrites /api/* to apps/functions.
# Set this only if the admin app should call the deployed functions app directly.
VITE_API_BASE_URL=

# Optional local-dev override for the Vite /api proxy target.
# Defaults to http://localhost:8787 when omitted.
VITE_API_PROXY_TARGET=
