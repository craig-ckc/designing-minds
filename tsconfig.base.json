{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@designing-minds/cms": ["./packages/cms/src/index.ts"],
      "@designing-minds/cms/*": ["./packages/cms/src/*"],
      "@designing-minds/utils": ["./packages/utils/src/index.ts"],
      "@designing-minds/utils/*": ["./packages/utils/src/*"]
    }
  }
}
